{
  "crons": [
    {
      "path": "/api/process-emails?token=${CRON_SECRET}",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/daily-summary?token=${CRON_SECRET}",
      "schedule": "0 15 * * *"
    }
  ],
  "functions": {
    "api/process-emails.js": {
      "maxDuration": 60
    },
    "api/daily-summary.js": {
      "maxDuration": 30
    }
  }
}
